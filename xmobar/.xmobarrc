Config { font = "xft:Sans-10"
       , bgColor = "#2c3e50"
       , fgColor = "#ecf0f1"
       , position = Top
       , lowerOnStart = True
       , commands = [ Run Cpu ["-L","3","-H","50","--normal","green","--high","red"] 10
                    , Run Memory ["-t","Mem: <usedratio>%"] 10
                    , Run Date "%a %b %_d %Y %H:%M" "date" 10
                    , Run Alsa "default" "Master" ["-t", "Vol: <volume>% <status>"]
                    , Run StdinReader
                    ]
       , sepChar = "%"
       , alignSep = "}{"
       , template = " %StdinReader% }{ %cpu% | %memory% | %alsa:default:Master% | <fc=#f1c40f>%date%</fc> "
       }