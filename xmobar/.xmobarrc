Config { font = "xft:Sans-10"
       , bgColor = "#2c3e50"
       , fgColor = "#ecf0f1"
       , position = Top
       , lowerOnStart = True
       , commands = [ Run Cpu ["-L","3","-H","50","--normal","green","--high","red"] 10
                    , Run Memory ["-t","Mem: <usedratio>%"] 10
                    , Run Date "%a %b %_d %Y %H:%M" "date" 10
                    , Run Alsa "default" "Master" [ "-t", "<action=`amixer set Master 5%+` button=4><action=`amixer set Master 5%-` button=5>Vol: <volume>% <status></action></action>" ]
                    , Run UnsafeStdinReader
                    -- -t: template for battery (Left percentage, time left)
                    -- -L / -H: Low/High thresholds for color changes
                    , Run Battery ["-t", "Bat: <left>% (<timeleft>)", "-L", "20", "-H", "80", "--low", "red", "--normal", "orange", "--high", "green"] 60
                    ]
       , sepChar = "%"
       , alignSep = "}{"
       , template = " %UnsafeStdinReader% }{ %cpu% | %memory% | %battery% | %alsa:default:Master% | <fc=#f1c40f>%date%</fc> "
       }